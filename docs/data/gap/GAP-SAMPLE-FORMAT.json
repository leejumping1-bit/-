      "section_title": "\uc81c5\uc870 (\ud488\uc9c8\uacbd\uc601\uc2dc\uc2a4\ud15c \ubb38\uc11c\ud654 \uc694\uad6c\uc0ac\ud56d)",
      "status": "changed",
      "blocks": [
        { "type": "unchanged", "text": "\uc81c\uc870\uc5c5\uc790\ub294 \ud488\uc9c8\uacbd\uc601\uc2dc\uc2a4\ud15c\uc744 \ubb38\uc11c\ud654\ud558\uc5ec \uc720\uc9c0\ud558\uc5ec\uc57c \ud55c\ub2e4." },
        { "type": "deleted", "text": "\ubb38\uc11c\uc758 \ubcf4\uc874\uae30\uac04\uc740 \uc81c\ud488\uc218\uba85 \ub3d9\uc548 \ub610\ub294 \ucd5c\uc885 \ucd9c\ud558\uc77c\ubd80\ud130 3\ub144\uc73c\ub85c \ud55c\ub2e4." },
        { "type": "added", "text": "\ubb38\uc11c\uc758 \ubcf4\uc874\uae30\uac04\uc740 \uc81c\ud488\uc218\uba85 \ub3d9\uc548 \ub610\ub294 \ucd5c\uc885 \ucd9c\ud558\uc77c\ubd80\ud130 5\ub144(\uc81c\ud488\uc218\uba85\uc774 5\ub144\uc744 \ucd08\uacfc\ud558\ub294 \uacbd\uc6b0\uc5d0\ub294 \ud574\ub2f9 \uc218\uba85\uc5d0 \uc0c1\uc751\ud558\ub294 \uae30\uac04)\uc73c\ub85c \ud55c\ub2e4." },
        { "type": "added", "text": "\uc804\uc790\ubb38\uc11c\ub85c \uad00\ub9ac\ud558\ub294 \uacbd\uc6b0 \uc811\uadfc\uad8c\ud55c \ubc0f \ubcc0\uacbd\uc774\ub825\uc744 \ud568\uaed8 \uae30\ub85d\ud558\uc5ec\uc57c \ud55c\ub2e4." }
      ]
